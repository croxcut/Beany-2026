{
  "extends": "expo/tsconfig.base",
  "ignoreDeprecations": "6.0",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".", 
    "paths": {
      "@/*": ["app/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
